{"+__ruleListOf_auto switch":{"color":"#99dd99","defaultProfileName":"LocalProxy","format":"Switchy","lastUpdate":"2026-06-25T12:33:12.069Z","matchProfileName":"direct","name":"__ruleListOf_auto switch","pacScript":"var FindProxyForURL = function(init, profiles) {\n    return function(url, host) {\n        \"use strict\";\n        var result = init, scheme = url.substr(0, url.indexOf(\":\"));\n        do {\n            if (!profiles[result]) return result;\n            result = profiles[result];\n            if (typeof result === \"function\") result = result(url, host, scheme);\n        } while (typeof result !== \"string\" || result.charCodeAt(0) === 43);\n        return result;\n    };\n}(\"+__tempZeroRuleListPac\", {\n    \"+__tempZeroRuleListPac\": function(url, host, scheme) {\n        \"use strict\";\n        if (/(?:^|\\.)redditspace\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)rlcdn\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)devvit\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)redditmedia\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)redd\\.it$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)redditstatic\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)static-storage\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)naydex\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)yandex\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)yastatic\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)vkuseraudio\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)mradx\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)vk-portal\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)userapi\\.com$/.test(host)) return \"DIRECT\";\n        if (/vk\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)ru$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)su$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)\\u0440\\u0444$/.test(host)) return \"DIRECT\";\n        if (/reddit\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)skcrtxr\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)adhigh\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)gismeteo\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)gismeteo\\.st$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)clstorage\\.net$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)avito\\.st$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)vigo\\.tech$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)ozonusercontent\\.com$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)ozonru\\.me$/.test(host)) return \"DIRECT\";\n        if (/(?:^|\\.)2gis\\.com$/.test(host)) return \"DIRECT\";\n        return \"+LocalProxy\";\n    }\n});","profileType":"RuleListProfile","revision":"19efec5907c","ruleList":"[SwitchyOmega Conditions]\n; Require: ZeroOmega >= 2.3.2\n; Date: 06.05.2026\n; Usage: https://github.com/FelisCatus/SwitchyOmega/wiki/RuleListUsage\n\n*.redditspace.com\n*.rlcdn.com\n*.devvit.net\n*.redditmedia.com\n*.redd.it\n*.redditstatic.com\n*.static-storage.net\n*.naydex.net\n*.yandex.net\n*.yastatic.net\n*.vkuseraudio.net\n*.mradx.net\n*.vk-portal.net\n*.userapi.com\n*vk.com\n*.ru\n*.su\n*.рф\n*reddit.com\n*.skcrtxr.com\n*.adhigh.net\n*.gismeteo.net\n*.gismeteo.st\n*.clstorage.net\n*.avito.st\n*.vigo.tech\n*.ozonusercontent.com\n*.ozonru.me\n*.2gis.com","sha256":"27b8def77b9fe9169166498005b785b13a59863c76fb14a64179314b4b5eb84f","sourceUrl":"https://raw.githubusercontent.com/Kudes1/omega-rulesets/refs/heads/main/direct-ru.txt"},"+auto switch":{"color":"#99dd99","defaultProfileName":"__ruleListOf_auto switch","name":"auto switch","profileType":"SwitchProfile","revision":"19efec5f5ef","rules":[{"condition":{"conditionType":"HostWildcardCondition","pattern":"sigma.deeplay.io"},"profileName":"LocalProxy"},{"condition":{"conditionType":"HostWildca